#!/usr/bin/env bash
set -euo pipefail

# curious-stack setup
# Detects install location and harness, configures telemetry, wires everything up.

BOLD='\033[1m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
HOST=""
NO_TELEMETRY=false
YES_TELEMETRY=false
DEV_MODE=false

# Telemetry endpoint
TELEMETRY_ENDPOINT="${AGENT_SKILLS_TELEMETRY_URL:-https://innwfuesrwrqbvxocfgs.supabase.co/functions/v1/telemetry-ingest}"

# Parse flags
while [ $# -gt 0 ]; do
  case "$1" in
    --host) HOST="${2:-}"; shift 2 ;;
    --host=*) HOST="${1#--host=}"; shift ;;
    --no-telemetry) NO_TELEMETRY=true; shift ;;
    --telemetry) YES_TELEMETRY=true; shift ;;
    --dev) DEV_MODE=true; shift ;;
    *) shift ;;
  esac
done

echo ""
echo -e "${BOLD}curious-stack${NC} setup"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# Detect harness
if [ -n "$HOST" ]; then
  HARNESS="$HOST"
elif [[ "$SCRIPT_DIR" == *".claude"* ]] || command -v claude &>/dev/null; then
  HARNESS="claude-code"
elif [[ "$SCRIPT_DIR" == *".codex"* ]] || command -v codex &>/dev/null; then
  HARNESS="codex"
elif [[ "$SCRIPT_DIR" == *".cursor"* ]]; then
  HARNESS="cursor"
elif [[ "$SCRIPT_DIR" == *".aider"* ]]; then
  HARNESS="aider"
else
  HARNESS="generic"
fi

echo -e "  Harness:  ${GREEN}$HARNESS${NC}"
echo -e "  Location: ${GREEN}$SCRIPT_DIR${NC}"

# Count available skills
SKILL_COUNT=$(find "$SCRIPT_DIR/skills" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | wc -l)
echo -e "  Skills:   ${GREEN}$SKILL_COUNT${NC}"

# ── Telemetry config ──────────────────────────────────────────────────

CONFIG_DIR="$HOME/.curious-stack"
CONFIG_FILE="$CONFIG_DIR/config.json"

mkdir -p "$CONFIG_DIR"

if [ ! -f "$CONFIG_FILE" ]; then
  # First install — ask for consent (default: off)
  if [ "$NO_TELEMETRY" = "true" ]; then
    TELEMETRY_CHOICE=false
  elif [ "$YES_TELEMETRY" = "true" ]; then
    TELEMETRY_CHOICE=true
  else
    echo ""
    echo -e "  ${BOLD}Anonymous usage telemetry${NC}"
    echo "  Collects: skill name, verdict category, input/output length."
    echo "  Never collects: actual text, file paths, or personal info."
    echo "  Details: evals/TELEMETRY.md"
    echo ""
    echo -n "  Share anonymous usage data to help improve skills? [y/N] "
    # Auto-select N after 15 seconds
    if read -t 15 -r answer; then
      case "$answer" in
        [yY]|[yY][eE][sS]) TELEMETRY_CHOICE=true ;;
        *) TELEMETRY_CHOICE=false ;;
      esac
    else
      echo "N (auto)"
      TELEMETRY_CHOICE=false
    fi
  fi

  python3 -c "
import json
config = {'telemetry': $TELEMETRY_CHOICE, 'harness': '$HARNESS'}
if $TELEMETRY_CHOICE:
    config['telemetry_endpoint'] = '$TELEMETRY_ENDPOINT'
json.dump(config, open('$CONFIG_FILE','w'), indent=2)
" 2>/dev/null || echo "{\"telemetry\": $TELEMETRY_CHOICE}" > "$CONFIG_FILE"

  if [ "$TELEMETRY_CHOICE" = "true" ]; then
    echo -e "  Telemetry: ${GREEN}on${NC}"
  else
    echo -e "  Telemetry: ${YELLOW}off${NC}"
  fi
else
  # Existing config — respect existing preference, allow overrides
  if [ "$NO_TELEMETRY" = "true" ]; then
    python3 -c "
import json
c = json.load(open('$CONFIG_FILE'))
c['telemetry'] = False
json.dump(c, open('$CONFIG_FILE','w'), indent=2)
" 2>/dev/null
    echo -e "  Telemetry: ${YELLOW}off${NC} (disabled)"
  elif [ "$YES_TELEMETRY" = "true" ]; then
    python3 -c "
import json
c = json.load(open('$CONFIG_FILE'))
c['telemetry'] = True
c['telemetry_endpoint'] = '$TELEMETRY_ENDPOINT'
json.dump(c, open('$CONFIG_FILE','w'), indent=2)
" 2>/dev/null
    echo -e "  Telemetry: ${GREEN}on${NC} (enabled)"
  else
    TELEMETRY_STATUS=$(python3 -c "import json; print(json.load(open('$CONFIG_FILE')).get('telemetry', False))" 2>/dev/null || echo "False")
    if [ "$TELEMETRY_STATUS" = "True" ]; then
      # Ensure endpoint is set when telemetry is on (may have been enabled manually)
      python3 -c "
import json
c = json.load(open('$CONFIG_FILE'))
if 'telemetry_endpoint' not in c:
    c['telemetry_endpoint'] = '$TELEMETRY_ENDPOINT'
    json.dump(c, open('$CONFIG_FILE','w'), indent=2)
" 2>/dev/null || true
      echo -e "  Telemetry: ${GREEN}on${NC}"
    else
      echo -e "  Telemetry: ${YELLOW}off${NC}"
    fi
  fi
fi

# ── Make scripts executable ───────────────────────────────────────────

chmod +x "$SCRIPT_DIR/scripts/"*.sh "$SCRIPT_DIR/scripts/"*.py 2>/dev/null || true
chmod +x "$SCRIPT_DIR/scripts/runners/"*.sh 2>/dev/null || true
chmod +x "$SCRIPT_DIR/scripts/hooks/"*.sh 2>/dev/null || true
chmod +x "$SCRIPT_DIR/setup" 2>/dev/null || true

# ── Register telemetry hook ──────────────────────────────────────────

HOOK_SCRIPT="$SCRIPT_DIR/scripts/hooks/log-telemetry.sh"
if [ "$HARNESS" = "claude-code" ]; then
  SETTINGS_FILE="$HOME/.claude/settings.json"
  python3 -c "
import json, os

settings_file = '$SETTINGS_FILE'
hook_cmd = '$HOOK_SCRIPT'

# Read existing settings or start fresh
if os.path.isfile(settings_file):
    with open(settings_file) as f:
        settings = json.load(f)
else:
    settings = {}

# Ensure hooks.PostToolUse exists
hooks = settings.setdefault('hooks', {})
post_hooks = hooks.setdefault('PostToolUse', [])

# Check if our hook is already registered
already = any(
    any(h.get('command') == hook_cmd for h in entry.get('hooks', []))
    for entry in post_hooks
)

if not already:
    post_hooks.append({
        'matcher': 'Skill',
        'hooks': [{
            'type': 'command',
            'command': hook_cmd
        }]
    })
    with open(settings_file, 'w') as f:
        json.dump(settings, f, indent=2)
" 2>/dev/null && echo -e "  Hook:      ${GREEN}registered${NC} (PostToolUse → telemetry)" || true

  # Register learnings hook
  LEARNINGS_HOOK="$SCRIPT_DIR/scripts/hooks/log-learnings.sh"
  python3 -c "
import json, os

settings_file = '$SETTINGS_FILE'
hook_cmd = '$LEARNINGS_HOOK'

if os.path.isfile(settings_file):
    with open(settings_file) as f:
        settings = json.load(f)
else:
    settings = {}

hooks = settings.setdefault('hooks', {})
post_hooks = hooks.setdefault('PostToolUse', [])

already = any(
    any(h.get('command') == hook_cmd for h in entry.get('hooks', []))
    for entry in post_hooks
)

if not already:
    post_hooks.append({
        'matcher': 'Skill',
        'hooks': [{
            'type': 'command',
            'command': hook_cmd
        }]
    })
    with open(settings_file, 'w') as f:
        json.dump(settings, f, indent=2)
" 2>/dev/null && echo -e "  Hook:      ${GREEN}registered${NC} (PostToolUse → learnings)" || true
fi

# ── Create symlinks for skill discovery ──────────────────────────────

SKILLS_ROOT=""
case "$HARNESS" in
  claude-code) SKILLS_ROOT="$HOME/.claude/skills" ;;
  codex)       SKILLS_ROOT="$HOME/.codex/skills" ;;
  cursor)      SKILLS_ROOT="$HOME/.cursor/skills" ;;
  *)           SKILLS_ROOT="$HOME/.claude/skills" ;;
esac

mkdir -p "$SKILLS_ROOT"

# User skills: installed for everyone
USER_SKILLS="ai-slop-detector claim-checker jargon-detector structure-critic tone-audit originality-score feed-scanner upgrade-skills"
# Developer skills: only with --dev flag
DEV_SKILLS="create-skill improve-skill eval-skill usage-dashboard auto-eval"

link_skill() {
  local skill_dir="$1"
  local name=$(basename "$skill_dir")
  local target="$SKILLS_ROOT/$name"

  if [ -L "$target" ] || [ -d "$target" ]; then
    current=$(readlink "$target" 2>/dev/null || echo "")
    if [ "$current" != "$skill_dir" ] && [ "$current" != "${skill_dir%/}" ]; then
      rm -f "$target"
      ln -s "${skill_dir%/}" "$target"
    fi
  else
    ln -s "${skill_dir%/}" "$target"
  fi
}

print_skill() {
  local skill_dir="$1"
  local name=$(basename "$skill_dir")
  if [ -f "$skill_dir/manifest.json" ] && command -v python3 &>/dev/null; then
    desc=$(python3 -c "import json; print(json.load(open('$skill_dir/manifest.json')).get('description', ''))" 2>/dev/null || echo "")
    echo -e "  ${GREEN}/$name${NC} — $desc"
  else
    echo -e "  ${GREEN}/$name${NC}"
  fi
}

echo ""
echo -e "${BOLD}User skills:${NC}"
for name in $USER_SKILLS; do
  skill_dir="$SCRIPT_DIR/skills/$name"
  [ -d "$skill_dir" ] || continue
  link_skill "$skill_dir"
  print_skill "$skill_dir"
done

if [ "$DEV_MODE" = "true" ]; then
  echo ""
  echo -e "${BOLD}Developer skills:${NC}"
  for name in $DEV_SKILLS; do
    skill_dir="$SCRIPT_DIR/skills/$name"
    [ -d "$skill_dir" ] || continue
    link_skill "$skill_dir"
    print_skill "$skill_dir"
  done
else
  echo ""
  echo -e "  ${YELLOW}Developer skills available with:${NC} ./setup --dev"
  echo -e "  (create-skill, improve-skill, eval-skill, usage-dashboard)"
fi

echo ""
echo -e "  Skills linked to: ${BLUE}$SKILLS_ROOT${NC}"

echo ""
echo -e "${GREEN}Setup complete.${NC}"
echo -e "  Telemetry:  ${BOLD}./setup --telemetry${NC} to enable, ${BOLD}./setup --no-telemetry${NC} to disable"
echo -e "  Upgrade:    ${BOLD}/upgrade-skills${NC}"
echo ""
